# Copy this file to .env and fill in your keys.
# gitchat reads .env at startup from the project root, the current working
# directory, or $GITCHAT_ENV_FILE. Values already set in your shell env win.

# Required for: pseudocode generation in the file viewer, and importing shared
# Claude/ChatGPT chats from the canvas toolbar.
ANTHROPIC_API_KEY=sk-ant-...
